<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Plumori | Detalle del Producto</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-color: #f5f5f7;
            --card-bg: #ffffff;
            --text-main: #1d1d1f;
            --text-muted: #86868b;
            --radius-premium: 26px;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Inter', sans-serif; -webkit-font-smoothing: antialiased; }
        body { background-color: var(--bg-color); color: var(--text-main); padding-bottom: 120px; }

        nav {
            position: fixed; top: 0; width: 100%; background: rgba(245, 245, 247, 0.8);
            backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); z-index: 1000;
            border-bottom: 1px solid rgba(0,0,0,0.05);
        }
        .nav-container { max-width: 1000px; margin: 0 auto; display: flex; justify-content: space-between; align-items: center; padding: 15px 20px; }
        .logo { font-weight: 600; font-size: 1.2rem; text-decoration: none; color: var(--text-main); }
        .back-link { color: #0071e3; text-decoration: none; font-size: 0.9rem; }

        /* Diseño de producto estilo Apple */
        .product-container { max-width: 1000px; margin: 120px auto 40px auto; padding: 0 20px; display: grid; grid-template-columns: 1fr 1fr; gap: 50px; align-items: center; }
        .product-gallery img { width: 100%; border-radius: var(--radius-premium); box-shadow: 0 8px 30px rgba(0,0,0,0.04); background: #fff; }
        
        .product-info h1 { font-size: 2.8rem; font-weight: 600; letter-spacing: -1px; margin-bottom: 15px; }
        .price-tag { font-size: 1.5rem; font-weight: 400; color: var(--text-muted); margin-bottom: 25px; }
        .description-text { font-size: 1.05rem; line-height: 1.6; color: #434344; margin-bottom: 35px; }
        
        .btn-add { background: #1d1d1f; color: white; border: none; padding: 16px 35px; border-radius: 30px; font-size: 1rem; font-weight: 500; cursor: pointer; width: 100%; transition: background 0.3s; }
        .btn-add:hover { background: #434344; }

        /* Barra Inferior del Carrito */
        .cart-bar {
            position: fixed; bottom: 30px; left: 50%; transform: translateX(-50%);
            width: calc(100% - 40px); max-width: 600px; background: rgba(29, 29, 31, 0.96);
            backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
            border-radius: 20px; padding: 15px 25px; display: flex; justify-content: space-between;
            align-items: center; color: white; box-shadow: 0 10px 40px rgba(0,0,0,0.2);
            z-index: 999; visibility: hidden; opacity: 0; transition: all 0.4s ease;
        }
        .cart-bar.active { visibility: visible; opacity: 1; transform: translateX(-50%) translateY(0); }
        .cart-info p { font-size: 0.9rem; color: #a1a1a6; }
        .cart-info h4 { font-size: 1.1rem; font-weight: 500; margin-top: 2px; }
        .btn-checkout { background: #0071e3; color: white; text-decoration: none; padding: 10px 20px; border-radius: 20px; font-size: 0.9rem; font-weight: 500; transition: background 0.2s; }
        .btn-checkout:hover { background: #147ce5; }

        @media (max-width: 768px) {
            .product-container { grid-template-columns: 1fr; gap: 30px; }
            .product-info h1 { font-size: 2rem; }
        }
    </style>
</head>
<body>

    <!-- MENÚ SUPERIOR -->
    <nav>
        <div class="nav-container">
            <!-- Corregido el retorno a index.html -->
            <a href="index.html" class="logo">plumori</a>
            <a href="index.html" class="back-link">‹ Volver al catálogo</a>
        </div>
    </nav>

    <!-- CONTENEDOR DINÁMICO -->
    <div class="product-container">
        <div class="product-gallery">
            <img id="p-img" src="" alt="Cargando...">
        </div>
        <div class="product-info">
            <h1 id="p-titulo">Cargando...</h1>
            <div class="price-tag" id="p-precio">$0 MXN</div>
            <p class="description-text" id="p-desc">Cargando detalles...</p>
            <button class="btn-add" onclick="agregarAlCarrito()">Añadir a la bolsa</button>
        </div>
    </div>

    <!-- BARRA FLOTANTE DEL CARRITO -->
    <div class="cart-bar" id="cartBar">
        <div class="cart-info">
            <p id="cartItems">Bolsa: 0 productos</p>
            <h4 id="cartTotal">Total: $0 MXN</h4>
        </div>
        <a href="#" id="whatsappBtn" target="_blank" class="btn-checkout">Comprar en WhatsApp</a>
    </div>

    <script>
        let carrito = JSON.parse(localStorage.getItem('plumori_cart')) || [];
        let productoActual = {};

        // Carga los datos del té seleccionado
        window.onload = function() {
            const data = localStorage.getItem('productoSeleccionado');
            if(data) {
                productoActual = JSON.parse(data);
                document.getElementById('p-titulo').innerText = productoActual.nombre;
                document.getElementById('p-precio').innerText = `$${productoActual.precio} MXN`;
                document.getElementById('p-desc').innerText = productoActual.descripcion;
                document.getElementById('p-img').src = productoActual.imagen;
            }
            actualizarInterfazCarrito();
        }

        function agregarAlCarrito() {
            const existe = carrito.find(item => item.nombre === productoActual.nombre);
            if(existe) {
                existe.cantidad += 1;
            } else {
                carrito.push({
                    nombre: productoActual.nombre,
                    precio: productoActual.precio,
                    cantidad: 1
                });
            }
            localStorage.setItem('plumori_cart', JSON.stringify(carrito));
            actualizarInterfazCarrito();
        }

        function actualizarInterfazCarrito() {
            const cartBar = document.getElementById('cartBar');
            if(carrito.length === 0) {
                cartBar.classList.remove('active');
                return;
            }

            cartBar.classList.add('active');
            
            let totalProductos = 0;
            let precioTotal = 0;
            let mensajeWhatsApp = "Hola Plumori! Me gustaría hacer un pedido:\n\n";

            carrito.forEach(item => {
                totalProductos += item.cantidad;
                precioTotal += (item.precio * item.cantidad);
                mensajeWhatsApp += `• ${item.cantidad}x ${item.nombre} ($${item.precio} MXN c/u)\n`;
            });

            mensajeWhatsApp += `\n*Total a pagar: $${precioTotal} MXN*`;

            document.getElementById('cartItems').innerText = `Bolsa: ${totalProductos} producto(s)`;
            document.getElementById('cartTotal').innerText = `Total: $${precioTotal} MXN`;
            
            const encodedText = encodeURIComponent(mensajeWhatsApp);
            // Tu número de México integrado
            document.getElementById('whatsappBtn').href = `https://wa.me/522723460967?text=${encodedText}`;
        }
    </script>
</body>
</html>
